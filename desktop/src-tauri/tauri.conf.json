{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mimoe",
  "version": "0.1.0",
  "identifier": "app.mimoe.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Mimoe",
        "label": "main",
        "width": 420,
        "height": 620,
        "resizable": false,
        "visible": false,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data: blob:; connect-src 'self' ipc: http://ipc.localhost http: https: ws: wss:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$DATA/app.mimoe/clipimg/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Apple Development: dupas.dev@gmail.com (8N9R4399V2)",
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNEN0Y3QzdDQTBDQkQxNzcKUldSMzBjdWdmSHgvUFlRV3p2YjdLcjV0S0RDTUJMNGxVd0ZkZThEdzJVdEhiamZlc3VKdHNnblQK",
      "endpoints": [
        "https://github.com/kevindupas/mimoe/releases/latest/download/latest.json"
      ]
    }
  }
}
