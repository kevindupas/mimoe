{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clipd",
  "version": "0.1.0",
  "identifier": "app.clipd.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Clipd",
        "label": "main",
        "width": 420,
        "height": 620,
        "resizable": false,
        "visible": false,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/Library/Application Support/app.clipd/clipimg/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Apple Development: dupas.dev@gmail.com (8N9R4399V2)",
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1RTc5QkYxQjVDQzFGNEUKUldST0g4eTE4WnZuMWVpQy9uS3JGaExPT1lWa0R3QlMraUZzT2JNTC9kNEh1UVUzMXl4eDc1MU0K",
      "endpoints": [
        "https://github.com/kevindupas/clipd/releases/latest/download/latest.json"
      ]
    }
  }
}
