{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clipd",
  "version": "0.1.0",
  "identifier": "app.clipd.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Clipd",
        "label": "main",
        "width": 420,
        "height": 620,
        "resizable": false,
        "visible": false,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Apple Development: dupas.dev@gmail.com (8N9R4399V2)",
      "entitlements": "entitlements.plist"
    }
  }
}
