# Copy to .env then generate a key: docker compose run --rm app php artisan key:generate --show
APP_NAME=Mimoe
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

# Database (the compose "db" service)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=mimoe
DB_USERNAME=mimoe
DB_PASSWORD=change-me

# Real-time + queues
BROADCAST_CONNECTION=reverb
QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database

# Reverb - CHANGE these values (especially the key and secret)
REVERB_APP_ID=mimoe
REVERB_APP_KEY=change-me-app-key
REVERB_APP_SECRET=change-me-app-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http
# Port clients use to reach Reverb (useful behind a reverse proxy).
REVERB_CLIENT_PORT=8080

# History
MIMOE_TTL_HOURS=24

# FCM push notifications (Android). Path to the Firebase service account JSON
# (mount as a volume in the container). Empty = no push (no-op).
FIREBASE_CREDENTIALS=/app/storage/app/firebase/service-account.json
MIMOE_MAX_CLIPS=100
