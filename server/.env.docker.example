# Copie en .env puis génère une clé : docker compose run --rm app php artisan key:generate --show
APP_NAME=Clipd
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

# Base de données (le service "db" du compose)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=clipd
DB_USERNAME=clipd
DB_PASSWORD=change-me

# Temps réel + files
BROADCAST_CONNECTION=reverb
QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database

# Reverb — CHANGE ces valeurs (surtout la clé et le secret)
REVERB_APP_ID=clipd
REVERB_APP_KEY=change-me-app-key
REVERB_APP_SECRET=change-me-app-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http
# Port que les clients utilisent pour joindre Reverb (utile si reverse proxy).
REVERB_CLIENT_PORT=8080

# Historique
CLIPD_TTL_HOURS=24
CLIPD_MAX_CLIPS=100
